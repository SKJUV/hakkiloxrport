  "shaderCode": "\nvec2 uv=(FC.xy-0.5*r)/r.y;\nfloat rl=u_cameraRoll;\nuv=mat2(cos(rl),-sin(rl),sin(rl),cos(rl))*uv;\nvec3 ro=u_cameraPosition;\nvec3 rd=normalize(vec3(uv,slider_zoom));\nrd=rotate3D(u_cameraRotation.x,vec3(1.0,0.0,0.0))*rd;\nrd=rotate3D(u_cameraRotation.y,vec3(0.0,1.0,0.0))*rd;\n\nvec3 zenith=vec3(0.55,0.71,0.92);\nvec3 horizon=vec3(0.99,0.86,0.79);\nfloat skyT=clamp(rd.y*1.25+0.18,0.0,1.0);\nvec3 sky=mix(horizon,zenith,skyT);\nvec3 sunDir=normalize(vec3(0.18,slider_sunElevation,1.0));\nfloat sun=max(dot(rd,sunDir),0.0);\nsky+=vec3(1.0,0.93,0.82)*pow(sun,60.0)*0.7;\nsky+=vec3(1.0,0.9,0.8)*pow(sun,5.0)*0.10;\nfloat cl=smoothstep(0.55,0.85,sin(rd.x*3.0+t*0.03)*0.5+0.5)*smoothstep(0.02,0.32,rd.y);\nsky=mix(sky,vec3(1.0,0.99,0.98),cl*0.22);\n\nvec3 col=sky;\nif(rd.y<-0.002){\n  float tg=-ro.y/rd.y;\n  if(tg>0.0&&tg<400.0){\n    vec3 pos=ro+rd*tg;\n    float z=pos.z;\n    float roadX=7.0*sin(z*0.045)+3.5*sin(z*0.045*0.37);\n    float dRoad=abs(pos.x-roadX);\n    float road=1.0-smoothstep(1.0,1.35,dRoad);\n    float hills=0.5+0.5*sin(pos.z*0.07)*sin(pos.x*0.045);\n    vec3 grass=mix(vec3(0.60,0.74,0.57),vec3(0.72,0.82,0.63),hills);\n    vec3 roadCol=vec3(0.91,0.87,0.81);\n    float dash=step(0.55,fract(z*0.45));\n    float centerLine=(1.0-smoothstep(0.05,0.11,abs(pos.x-roadX)))*dash;\n    vec3 g=mix(grass,roadCol,road);\n    g=mix(g,vec3(0.99,0.96,0.74),centerLine*0.55);\n    float edge=(1.0-smoothstep(1.35,1.7,dRoad))*(smoothstep(1.0,1.35,dRoad));\n    g=mix(g,vec3(0.80,0.90,0.95),edge*0.25*slider_colorEffectStrength);\n    col=g;\n    float fog=1.0-exp(-tg*slider_atmosphereDensity*0.035);\n    col=mix(col,sky,clamp(fog,0.0,1.0));\n  }\n}\ncol*=slider_brightness;\ncol=clamp(col,0.0,1.0);\no=vec4(col,1.0);\n",
